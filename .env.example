# PostgreSQL connection settings (Neon Cloud)
DB_HOST=ep-xxxxx.us-east-1.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=your_password_here
DATABASE_URL=postgresql://neondb_owner:your_password_here@ep-xxxxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Ollama settings (for AI tagging)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=mistral

# API server settings
API_PORT=8001
